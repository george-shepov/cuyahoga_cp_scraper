{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cuyahoga Criminal Case",
  "type": "object",
  "properties": {
    "case_id": {
      "type": "string"
    },
    "year": {
      "type": "integer"
    },
    "number": {
      "type": "integer"
    },
    "urls": {
      "type": "object"
    },
    "summary": {
      "type": "object"
    },
    "docket": {
      "type": "array"
    },
    "costs": {
      "type": "array"
    },
    "defendant": {
      "type": "object"
    },
    "attorneys": {
      "type": "array"
    },
    "fetched_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "case_id",
    "year",
    "number",
    "fetched_at"
  ]
}