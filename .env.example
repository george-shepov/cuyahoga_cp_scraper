# Example environment variables for local development.
# Copy this file to `.env` and fill in real values locally.

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cuyahoga_cases
POSTGRES_USER=cuyahoga
POSTGRES_PASSWORD=changeme

MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=cuyahoga_cases
MONGO_USER=cuyahoga
MONGO_PASSWORD=changeme

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# LLM / API keys
OLLAMA_BASE_URL=http://ollama:11434
LLM_PROVIDER=ollama
LLM_MODEL=llama3
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Email review workflow
REVIEW_SONIA_NAME=Sonia
REVIEW_SONIA_EMAIL=
REVIEW_AARON_NAME=Aaron
REVIEW_AARON_EMAIL=

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# ── Admin authentication (2FA) ────────────────────────────────────────────────
# Run  python scripts/setup_admin_auth.py  to generate these values.
# The setup script outputs a QR code URL to scan with Google Authenticator / Authy.
#
ADMIN_USERNAME=brockler
ADMIN_PASSWORD_HASH=<bcrypt hash — generated by setup_admin_auth.py>
ADMIN_TOTP_SECRET=<base-32 TOTP secret — generated by setup_admin_auth.py>
JWT_SECRET_KEY=<32-byte hex secret — generated by setup_admin_auth.py>
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# CORS — comma-separated list of allowed origins for the FastAPI backend.
# Add your VPS domain if serving the frontend from a different origin.
ALLOWED_ORIGINS=http://localhost:5173,https://prosecutordefense.com,https://www.prosecutordefense.com

# ── Storage VPS (rsync target for scraped data) ───────────────────────────────
# Run  scripts/sync_to_storage_vps.sh  to push out/ to the remote server.
# SSH key must be added to the VPS's authorized_keys.
#
STORAGE_VPS_HOST=<vps-ip-or-hostname>
STORAGE_VPS_USER=<ssh-user>
STORAGE_VPS_PORT=22
STORAGE_VPS_PATH=/data/cuyahoga
STORAGE_VPS_SSH_KEY=~/.ssh/storage_vps_key

# Other
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
